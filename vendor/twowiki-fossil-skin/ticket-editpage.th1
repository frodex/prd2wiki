<th1>
  if {![info exists twowiki_skin_edit_rev]} {set twowiki_skin_edit_rev 20260415b}
  if {[lsearch [info commands] twowiki_md_hardbreaks_plain] < 0} {
  proc twowiki_md_hardbreaks_plain {txt} {
    set out ""
    set n [string length $txt]
    for {set i 0} {$i < $n} {set i [expr {$i+1}]} {
      set c [string index $txt $i]
      if {$c eq "\n"} {
        set out "${out}  \n"
      } else {
        set out "${out}$c"
      }
    }
    return $out
  }
  }
  if {[lsearch [info commands] twowiki_md_hardbreaks] < 0} {
  proc twowiki_md_hardbreaks {txt} {
    set res ""
    for {} {[string length $txt] > 0} {} {
      set p [string first "```" $txt]
      if {$p < 0} {
        set res "${res}[twowiki_md_hardbreaks_plain $txt]"
        break
      }
      if {$p > 0} {
        set head [string range $txt 0 [expr {$p-1}]]
        set res "${res}[twowiki_md_hardbreaks_plain $head]"
      }
      set rest [string range $txt $p end]
      set after [string range $rest 3 end]
      set qrel [string first "```" $after]
      if {$qrel < 0} {
        set res "${res}$rest"
        break
      }
      set abs [expr {3+$qrel}]
      set res "${res}[string range $rest 0 [expr {$abs+2}]]"
      set txt [string range $rest [expr {$abs+3}] end]
    }
    return $res
  }
  }
  if {![info exists mutype]} {set mutype Markdown}
  if {![info exists icomment]} {set icomment {}}
  if {![info exists username]} {set username $login}
  if {[info exists submit]} {
    if {$mutype eq "Wiki"} {
      set mimetype text/x-fossil-wiki
    } elseif {$mutype eq "Markdown"} {
      set mimetype text/x-markdown
    } elseif {$mutype eq "HTML"} {
      set mimetype text/html
    } elseif {$mutype eq {[links only]}} {
      set mimetype text/x-fossil-plain
    } else {
      set mimetype text/plain
    }
    submit_ticket
    set preview 1
  }
</th1>
<table cellpadding="5">
<tr><td class="tktDspLabel">Title:</td><td>
<input type="text" name="title" value="$<title>" size="60">
</td></tr>

<tr><td class="tktDspLabel">Status:</td><td>
<th1>combobox status $status_choices 1</th1>
</td></tr>

<tr><td class="tktDspLabel">Type:</td><td>
<th1>combobox type $type_choices 1</th1>
</td></tr>

<tr><td class="tktDspLabel">Severity:</td><td>
<th1>combobox severity $severity_choices 1</th1>
</td></tr>

<tr><td class="tktDspLabel">Priority:</td><td>
<th1>combobox priority $priority_choices 1</th1>
</td></tr>

<tr><td class="tktDspLabel">Resolution:</td><td>
<th1>combobox resolution $resolution_choices 1</th1>
</td></tr>

<tr><td class="tktDspLabel">Subsystem:</td><td>
<th1>combobox subsystem $subsystem_choices 1</th1>
</td></tr>

<th1>enable_output [hascap e]</th1>
  <tr><td class="tktDspLabel">Contact:</td><td>
  <input type="text" name="private_contact" size="40"
   value="$<private_contact>">
  </td></tr>
<th1>enable_output 1</th1>

<tr><td class="tktDspLabel">Version&nbsp;Found&nbsp;In:</td><td>
<input type="text" name="foundin" size="50" value="$<foundin>">
</td></tr>

<tr><td class="tktDspLabel" colspan="2"><hr><b>Page fields (twoWiki)</b></td></tr>
<tr><td colspan="2"><p class="twowiki-edit-hint">Page fields use <b>markdown</b>. <b>Preview</b> shows <b>page markdown</b> first, then the <b>new remark</b> (format from the dropdown). <b>Submit</b> applies ticket + remark. Plain line breaks in textareas become visible line breaks in markdown preview/view (CommonMark otherwise collapses them).</p></td></tr>
<tr><td class="tktDspLabel">page_path:</td><td>
<input type="text" name="page_path" value="$<page_path>" size="80">
</td></tr>
<tr><td class="tktDspLabel">tags:</td><td>
<input type="text" name="tags" value="$<tags>" size="80">
</td></tr>
<tr><td class="tktDspLabel">body (markdown):</td></tr>
<tr><td colspan="2">
<textarea name="body" cols="100" rows="22" wrap="virtual" class="wikiedit">$<body></textarea>
</td></tr>
<tr><td class="tktDspLabel">section_overview:</td></tr>
<tr><td colspan="2">
<textarea name="section_overview" cols="100" rows="8" wrap="virtual" class="wikiedit">$<section_overview></textarea>
</td></tr>
<tr><td class="tktDspLabel">section_api:</td></tr>
<tr><td colspan="2">
<textarea name="section_api" cols="100" rows="8" wrap="virtual" class="wikiedit">$<section_api></textarea>
</td></tr>
<tr><td class="tktDspLabel">section_storage:</td></tr>
<tr><td colspan="2">
<textarea name="section_storage" cols="100" rows="8" wrap="virtual" class="wikiedit">$<section_storage></textarea>
</td></tr>
<tr><td class="tktDspLabel">section_auth:</td></tr>
<tr><td colspan="2">
<textarea name="section_auth" cols="100" rows="8" wrap="virtual" class="wikiedit">$<section_auth></textarea>
</td></tr>

<tr><td colspan="2">
  Append Remark with format
  <th1>combobox mutype {HTML {[links only]} Markdown {Plain Text} Wiki} 1</th1>
  from
  <input type="text" name="username" value="$<username>" size="30">:<br>
  <textarea name="icomment" cols="80" rows="15"
   wrap="virtual" class="wikiedit">$<icomment></textarea>
</td></tr>

<th1>enable_output [info exists preview]</th1>
<tr><td colspan="2">
<b>twoWiki — page markdown preview</b><br><hr>
<th1>
  if {![info exists body]} {set body {}}
  if {[string trim $body] eq {}} {
    html "<p><i>(body empty)</i></p>\n"
  } else {
    set _b [string trimright $body]
    html [lindex [markdown [twowiki_md_hardbreaks $_b]] 1]
  }
  if {[info exists section_overview] && [string trim $section_overview] ne {}} {
    html "<h4 style=\"margin:1em 0 0.25em 0\">section_overview</h4>\n"
    set _s [string trimright $section_overview]
    html [lindex [markdown [twowiki_md_hardbreaks $_s]] 1]
  }
  if {[info exists section_api] && [string trim $section_api] ne {}} {
    html "<h4 style=\"margin:1em 0 0.25em 0\">section_api</h4>\n"
    set _s [string trimright $section_api]
    html [lindex [markdown [twowiki_md_hardbreaks $_s]] 1]
  }
  if {[info exists section_storage] && [string trim $section_storage] ne {}} {
    html "<h4 style=\"margin:1em 0 0.25em 0\">section_storage</h4>\n"
    set _s [string trimright $section_storage]
    html [lindex [markdown [twowiki_md_hardbreaks $_s]] 1]
  }
  if {[info exists section_auth] && [string trim $section_auth] ne {}} {
    html "<h4 style=\"margin:1em 0 0.25em 0\">section_auth</h4>\n"
    set _s [string trimright $section_auth]
    html [lindex [markdown [twowiki_md_hardbreaks $_s]] 1]
  }
</th1>
<hr>
<b>New remark preview</b> (uses format dropdown):<br><hr>
<th1>
if {$mutype eq "Wiki"} {
  wiki $icomment
} elseif {$mutype eq "Plain Text"} {
  set r [randhex]
  wiki "<verbatim-$r>\n[string trimright $icomment]\n</verbatim-$r>"
} elseif {$mutype eq "Markdown"} {
  set _ic [twowiki_md_hardbreaks $icomment]
  html [lindex [markdown "$_ic\n"] 1]
} elseif {$mutype eq {[links only]}} {
  set r [randhex]
  wiki "<verbatim-$r links>\n[string trimright $icomment]</verbatim-$r>"
} else {
  wiki "<nowiki>\n[string trimright $icomment]\n</nowiki>"
}
</th1>
<hr>
</td></tr>
<th1>enable_output 1</th1>

<tr>
<td align="right">
<input type="submit" name="preview" value="Preview">
</td>
<td align="left">See how the description will appear after formatting.</td>
</tr>

<th1>enable_output [info exists preview]</th1>
<tr>
<td align="right">
<input type="submit" name="submit" value="Submit">
</td>
<td align="left">Apply the changes shown above</td>
</tr>
<th1>enable_output 1</th1>

<tr>
<td align="right">
<input type="submit" name="cancel" value="Cancel">
</td>
<td>Abandon this edit</td>
</tr>

<th1>
set seenRow 0
set alwaysPlaintext [info exists plaintext]
query {SELECT datetime(tkt_mtime,toLocal()) AS xdate, login AS xlogin,
              mimetype as xmimetype, icomment AS xcomment,
              username AS xusername
         FROM ticketchng
        WHERE tkt_id=$tkt_id AND length(icomment)>0} {
  if {$seenRow} {
    html "<hr>\n"
  } else {
    html "<tr><td colspan='2'><hr></td></tr>\n"
    html "<tr><td colspan='2' class='tktDspLabel' style='text-align:left'>\n"
    html "Previous User Comments:</td></tr>\n"
    html "<tr><td colspan='2' class='tktDspValue'><div class='tktCommentArea'>\n"
    set seenRow 1
  }
  html "<div class='tktCommentEntry'>"
  html "<span class='tktDspCommenter'>"
  puts $xlogin
  if {$xlogin ne $xusername && [string length $xusername]>0} {
    puts " (claiming to be $xusername)"
  }
  puts " added on $xdate:"
  html "</span>\n"
  if {$alwaysPlaintext || $xmimetype eq "text/plain"} {
    set r [randhex]
    if {$xmimetype ne "text/plain"} {puts "($xmimetype)\n"}
    wiki "<verbatim-$r>[string trimright $xcomment]</verbatim-$r>\n"
  } elseif {$xmimetype eq "text/x-fossil-wiki"} {
    wiki "<p>\n[string trimright $xcomment]\n</p>\n"
  } elseif {$xmimetype eq "text/x-markdown"} {
    html [lindex [markdown [twowiki_md_hardbreaks $xcomment]] 1]
  } elseif {$xmimetype eq "text/html"} {
    wiki "<p><nowiki>\n[string trimright $xcomment]\n</nowiki>\n"
  } else {
    set r [randhex]
    wiki "<verbatim-$r links>[string trimright $xcomment]</verbatim-$r>\n"
  }
  html "</div>"; # .tktCommentEntry
}
if {$seenRow} {html "</div></td></tr>\n"}
</th1>

</table>
